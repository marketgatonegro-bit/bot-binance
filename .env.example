# ─── BINANCE API ──────────────────────────────────────────────────────────────
# Generá tus keys en: https://www.binance.com/en/my/settings/api-management
# Permisos necesarios: Solo "Enable Spot & Margin Trading" (NUNCA habilites retiros)
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# ─── CONFIGURACIÓN DEL BOT ────────────────────────────────────────────────────
# Par a operar (DOGE tiene mínimos bajos, ideal para montos pequeños)
SYMBOL=DOGEUSDT

# Cuántos USDT invertir por operación
TRADE_AMOUNT=5

# Porcentaje del trailing stop (3 = si el precio baja 3% desde el máximo, vende)
TRAILING_PERCENT=3

# Segundos entre cada verificación de precio
CHECK_INTERVAL=10

# true = simulado sin dinero real | false = dinero real
PAPER_TRADING=true
